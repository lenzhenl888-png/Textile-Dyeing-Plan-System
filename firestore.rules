rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authorized via email whitelist
    function isAuthorized() {
      return request.auth != null && (
        request.auth.token.email == 'len.zhenl888@gmail.com' ||
        request.auth.token.email == 'lz1041953343@gmail.com'
      );
    }

    // Allow read and write access to the 'plans' collection tracking
    match /plans/{document=**} {
      allow read, write: if isAuthorized();
    }

    // Allow read and write access to the 'fabrics' collection
    match /fabrics/{document=**} {
      allow read, write: if isAuthorized();
    }

    // Allow read and write access to the 'reminders' collection
    match /reminders/{document=**} {
      allow read, write: if isAuthorized();
    }

    // Allow read and write access to the 'contacts' collection
    match /contacts/{document=**} {
      allow read, write: if isAuthorized();
    }

    // Allow read and write access to the 'customers' collection
    match /customers/{document=**} {
      allow read, write: if isAuthorized();
    }
  }
}
